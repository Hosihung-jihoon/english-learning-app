# ============================================================
# api/.env.example — Template biến môi trường cho Backend
# ============================================================
# HƯỚNG DẪN:
#   1. Copy file này thành .env
#      cp .env.example .env   (Mac/Linux)
#      copy .env.example .env  (Windows)
#   2. Điền giá trị thật vào .env
#   3. KHÔNG BAO GIỜ commit file .env thật
# ============================================================

# --- Server ---
PORT=5000
NODE_ENV=development

# --- Database ---
# Lấy từ MongoDB Atlas (hỏi leader)
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/english-learning

# --- JWT Authentication ---
# Chuỗi bất kỳ, dài >= 32 ký tự, giữ bí mật
JWT_SECRET=your-super-secret-key-minimum-32-characters
JWT_EXPIRES_IN=7d

# --- CORS ---
# URL của mobile app khi test web (thường để * khi dev)
ALLOWED_ORIGINS=*
