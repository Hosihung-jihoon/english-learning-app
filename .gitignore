apps/mobile/ios/
apps/mobile/android/

# ============================================================
# EAS (Expo Application Services)
# ============================================================
# credentials.json chứa keystore/cert — KHÔNG bao giờ commit
credentials.json
apps/mobile/credentials.json
# eas.json có thể commit (không chứa secrets)
# !apps/mobile/eas.json

