# ============================================================
# .env.example — Template môi trường cho english-learning-app-t2
# ============================================================
# HƯỚNG DẪN:
#   1. Copy file này thành .env
#      cp .env.example .env
#   2. Điền giá trị thật vào .env (hỏi Team Lead nếu cần)
#   3. KHÔNG BAO GIỜ commit file .env thật
#   4. Khi thêm biến mới: thêm vào CẢ HAI file .env và .env.example
# ============================================================

# --- API & Backend ---
# Base URL của backend API (không có trailing slash)
EXPO_PUBLIC_API_BASE_URL=https://your-api-url.com

# --- Authentication ---
# Google OAuth 2.0 Client ID (từ Google Cloud Console)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE

# --- AI / NLP Services (nếu có) ---
# API Key cho dịch vụ AI (OpenAI, Gemini, v.v.)
EXPO_PUBLIC_AI_API_KEY=YOUR_AI_API_KEY_HERE

# --- Text-to-Speech (nếu có) ---
EXPO_PUBLIC_TTS_API_KEY=YOUR_TTS_API_KEY_HERE

# --- Analytics (nếu có) ---
EXPO_PUBLIC_ANALYTICS_KEY=YOUR_ANALYTICS_KEY_HERE

# ============================================================
# LƯU Ý VỀ EXPO PUBLIC VARIABLES:
# - Biến CÓ tiền tố EXPO_PUBLIC_ → accessible trên client (bundle vào app)
# - Biến KHÔNG có tiền tố → chỉ dùng trong app.config.js (build time)
# - Không đặt secrets thật vào biến EXPO_PUBLIC_ nếu không muốn expose
# ============================================================
