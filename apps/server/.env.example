# ============================================================
# apps/server/.env.example — Template biến môi trường NestJS
# ============================================================
# HƯỚNG DẪN:
#   1. Copy file này thành .env
#      copy .env.example .env   (Windows)
#      cp .env.example .env     (Mac/Linux)
#   2. Điền giá trị thật vào .env
#   3. KHÔNG BAO GIỜ commit file .env thật
# ============================================================

# --- Server ---
PORT=3000
NODE_ENV=development

# --- MongoDB Atlas ---
# Lấy từ: Atlas Console → Connect → Drivers → Node.js
# Format:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>
MONGODB_URI=mongodb+srv://<user>:<password>@cluster.mongodb.net/english_learning

# --- JWT Authentication ---
# Chuỗi bất kỳ, dài >= 32 ký tự, giữ bí mật
JWT_SECRET=your-super-secret-key-minimum-32-characters
JWT_EXPIRES_IN=7d

# --- CORS ---
# Danh sách origin cho phép, ngăn cách bằng dấu phẩy
# Để * khi dev Expo trên mạng LAN
ALLOWED_ORIGINS=*
